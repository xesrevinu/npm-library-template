{
  "name": "@xesrevinu/npm-library-template",
  "version": "0.1.0",
  "description": "Template repository for simple npm libraries built with Bun, tsdown, and Changesets.",
  "keywords": [
    "bun",
    "library",
    "npm",
    "template",
    "tsdown",
    "typescript"
  ],
  "homepage": "https://github.com/xesrevinu/npm-library-template#readme",
  "bugs": {
    "url": "https://github.com/xesrevinu/npm-library-template/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xesrevinu/npm-library-template.git"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "lefthook install && effect-tsgo patch",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "prepack": "bun run build",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@effect/platform-node": "4.0.0-beta.40",
    "@effect/tsgo": "0.0.20",
    "@effect/vitest": "4.0.0-beta.40",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "effect": "4.0.0-beta.40",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.6",
    "vitest": "^4.1.0"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24"
  },
  "knip": {
    "ignoreDependencies": [
      "@effect/language-service"
    ]
  }
}
